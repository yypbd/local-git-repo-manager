{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Git Repo Manager",
  "version": "1.0.0",
  "identifier": "com.yypbd.app.localgitrepomanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Local Git Repo Manager",
        "minWidth": 800,
        "minHeight": 600,
        "width": 1280,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
